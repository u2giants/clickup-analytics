# Copy to .env and fill in. KEY/SECRET: generate with `node -e "console.log(crypto.randomUUID())"` (run twice).
KEY=replace-with-uuid
SECRET=replace-with-uuid
PUBLIC_URL=https://pm.designflow.app
ADMIN_EMAIL=you@popcre.com
ADMIN_PASSWORD=change-me-strong

# Postgres
DB_DATABASE=directus
DB_USER=directus
DB_PASSWORD=change-me-strong

# Open Innovation Grant license key (you were awarded the grant) — uncomment LICENSE_KEY in compose too
# LICENSE_KEY=

# Cloudflare R2 (S3-compatible) file storage — keep full design files on NAS, thumbnails/attachments here
STORAGE_LOCATIONS=r2
STORAGE_R2_DRIVER=s3
STORAGE_R2_KEY=
STORAGE_R2_SECRET=
STORAGE_R2_BUCKET=pm-uploads
STORAGE_R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
STORAGE_R2_REGION=auto

# Microsoft Entra SSO (OIDC). Google works the same way with accounts.google.com issuer.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# For apply-schema.mjs / seed-and-verify.mjs (point at the running instance)
DX_URL=http://localhost:8055
DX_ADMIN_EMAIL=you@popcre.com
DX_ADMIN_PASSWORD=change-me-strong
